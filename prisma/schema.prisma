generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  STUDENT_DESIGNER
  NEW_DESIGNER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum UserPersona {
  DESIGNER
  FABRIC_SUPPLIER
  SAMPLE_STUDIO
  FACTORY
  BUYER
  CONSUMER
  TEACHER
  SCHOOL
  OTHER
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  OFFLINE
  PUBLISHED
  HIDDEN
}

enum ContentStatus {
  VISIBLE
  HIDDEN
  DELETED
  OFFLINE
}

enum ChallengeStatus {
  DRAFT
  PUBLISHED
  ACTIVE
  ENDED
  ARCHIVED
}

enum ExhibitionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum IncubationSource {
  USER_APPLY
  RECOMMEND_THRESHOLD
  EDITOR_REVIEW_THRESHOLD
  CHALLENGE_TOP
  EDITOR_PICK
  ADMIN
}

enum IncubationApplicationStatus {
  CANDIDATE
  REVIEWING
  NOT_SUITABLE
  ACCEPTED
}

enum IncubationStatus {
  CANDIDATE
  REVIEWING
  NOT_SUITABLE
  FABRIC_MATCHING
  SAMPLE_EVALUATING
  QUOTE_DISCUSSING
  PATTERN_EVALUATING
  SAMPLE_MAKING
  COOPERATION_DISCUSSING
  COMPLETED
}

enum WorkIncubationStatus {
  DISPLAYING
  CANDIDATE
  FABRIC_MATCHING
  SAMPLE_MATCHING
  PRODUCTION_MATCHING
  PRESALE_TESTING
  COLLABORATION_REACHED
}

enum ProposalStatus {
  PENDING
  INTERESTED
  ACCEPTED
  REJECTED
  INVALID
}

enum ProviderType {
  FABRIC_SUPPLIER
  SAMPLE_STUDIO
  FACTORY
  BUYER
  OTHER
}

enum ProviderStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum ProviderApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FabricStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum RecommendationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ProviderWorkProposalType {
  FABRIC
  SAMPLE
  PRODUCTION
  BUYER_INTENT
  OTHER
}

enum ProviderWorkProposalStatus {
  PENDING
  SHORTLISTED
  ACCEPTED
  REJECTED
}

enum PresaleCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum PresaleCampaignIntentStatus {
  SUBMITTED
  CONTACTED
  CONFIRMED
  CANCELLED
}

enum VerificationType {
  DESIGNER
  TEACHER
  SCHOOL
  FABRIC_SUPPLIER
  SAMPLE_STUDIO
  FACTORY
  BUYER
  OTHER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CollaborationProjectStatus {
  DRAFT
  MATCHING
  SAMPLING
  PRESALE_VALIDATING
  PRODUCTION_DISCUSSION
  COMPLETED
  CANCELLED
}

enum CollaborationProjectPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ProjectOrderStatus {
  INTENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ReviewTargetType {
  USER
  PROVIDER
  WORK
  PROJECT
}

enum CaseStudyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum RequestStatus {
  PENDING
  CONTACTED
  EVALUATED
  QUOTED
  CLOSED
  COMPLETED
}

enum CooperationType {
  OPEN_COOP
  COPYRIGHT
  BRAND_COLLAB
  SAMPLE_INCUBATION
  INTERNSHIP
}

enum ReportTargetType {
  WORK
  COMMENT
  USER
}

enum ReportReason {
  PLAGIARISM
  STOLEN_IMAGE
  VULGAR
  AD
  NON_FASHION
  AI_UNLABELED
  INFRINGEMENT
}

enum ReportStatus {
  PENDING
  HANDLED
  REJECTED
}

enum NotificationType {
  WORK_APPROVED
  WORK_REJECTED
  INCUBATION_RECOMMENDED
  INCUBATION_CANDIDATE
  REQUEST_HANDLED
  CHALLENGE_RESULT
}

model User {
  id               String      @id @default(cuid())
  email            String      @unique
  passwordHash     String
  nickname         String
  avatarUrl        String?
  role             UserRole    @default(USER)
  status           UserStatus  @default(ACTIVE)
  persona          UserPersona @default(CONSUMER)
  personaCompleted Boolean     @default(false)

  designerProfile           DesignerProfile?
  sessions                  AuthSession[]
  works                     Work[]
  comments                  Comment[]
  likes                     Like[]
  favorites                 Favorite[]
  challengeEntries          ChallengeEntry[]
  follows                   Follow[]                   @relation("Follower")
  followers                 Follow[]                   @relation("Following")
  incubationRecommendations IncubationRecommendation[]
  incubationApplications    IncubationApplication[]
  incubationProjects        IncubationProject[]        @relation("IncubationProjectDesigner")
  fabricRequests            FabricRequest[]
  sampleRequests            SampleRequest[]
  cooperationRequests       CooperationRequest[]
  reports                   Report[]                   @relation("Reporter")
  notifications             Notification[]

  handledWorks               Work[]                  @relation("WorkHandledBy")
  handledComments            Comment[]               @relation("CommentHandledBy")
  handledApplications        IncubationApplication[] @relation("IncubationApplicationHandledBy")
  handledProjects            IncubationProject[]     @relation("IncubationProjectHandledBy")
  handledFabricRequests      FabricRequest[]         @relation("FabricRequestHandledBy")
  handledSampleRequests      SampleRequest[]         @relation("SampleRequestHandledBy")
  handledCooperationRequests CooperationRequest[]    @relation("CooperationRequestHandledBy")
  handledReports             Report[]                @relation("ReportHandledBy")
  adminLogs                  AdminLog[]
  presaleCampaigns           PresaleCampaign[]       @relation("PresaleCampaignCreatedBy")
  presaleCampaignIntents     PresaleCampaignIntent[]
  verificationRequests       VerificationRequest[]   @relation("VerificationRequestUser")
  reviewedVerifications      VerificationRequest[]   @relation("VerificationReviewedBy")
  collaborationProjects      CollaborationProject[]  @relation("CollaborationProjectDesigner")
  createdProjects            CollaborationProject[]  @relation("CollaborationProjectCreatedBy")
  projectOrders              ProjectOrder[]          @relation("ProjectOrderBuyer")
  givenReviews               Review[]                @relation("ReviewReviewer")
  receivedReviews            Review[]                @relation("ReviewTargetUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model DesignerProfile {
  id                String  @id @default(cuid())
  userId            String  @unique
  school            String?
  city              String?
  designDirection   String?
  bio               String?
  cooperationStatus String?
  portfolioCoverUrl String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Work {
  id               String            @id @default(cuid())
  userId           String
  schoolId         String?
  teacherId        String?
  title            String
  description      String
  category         String
  workType         String
  styleTags        String[]
  reviewStatus     ReviewStatus      @default(PENDING)
  rejectReason     String?
  contentStatus    ContentStatus     @default(VISIBLE)
  isOriginal       Boolean           @default(false)
  isAiAssisted     Boolean           @default(false)
  isFeatured       Boolean           @default(false)
  isEditorPick     Boolean           @default(false)
  isOpenCoop       Boolean           @default(false)
  wantsFabric      Boolean           @default(false)
  wantsSample      Boolean           @default(false)
  wantsIncubation  Boolean           @default(false)
  incubationStatus IncubationStatus?

  viewCount                Int @default(0)
  likeCount                Int @default(0)
  favoriteCount            Int @default(0)
  commentCount             Int @default(0)
  shareCount               Int @default(0)
  incubationRecommendCount Int @default(0)

  adminNote   String?
  handledAt   DateTime?
  handledById String?

  user                      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  school                    School?                    @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  teacher                   Teacher?                   @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  handledBy                 User?                      @relation("WorkHandledBy", fields: [handledById], references: [id])
  images                    WorkImage[]
  comments                  Comment[]
  likes                     Like[]
  favorites                 Favorite[]
  challengeEntries          ChallengeEntry[]
  challengeWorks            ChallengeWork[]
  exhibitionWorks           ExhibitionWork[]
  teacherRecommendations    TeacherRecommendedWork[]
  incubationRecommendations IncubationRecommendation[]
  incubationApplications    IncubationApplication[]
  incubationProjects        IncubationProject[]
  workIncubation            WorkIncubation?
  fabricProposals           FabricProposal[]
  sampleProposals           SampleProposal[]
  factoryProposals          FactoryProposal[]
  buyerIntents              BuyerIntent[]
  presaleIntents            PresaleIntent[]
  presaleCampaigns          PresaleCampaign[]
  presaleCampaignIntents    PresaleCampaignIntent[]
  collaborationProjects     CollaborationProject[]
  projectOrders             ProjectOrder[]
  reviews                   Review[]
  caseStudies               CaseStudy[]
  fabricRecommendations     WorkFabricRecommendation[]
  providerWorkProposals     ProviderWorkProposal[]
  editorialPicks            EditorialPick[]
  fabricRequests            FabricRequest[]
  sampleRequests            SampleRequest[]
  cooperationRequests       CooperationRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([reviewStatus, contentStatus])
  @@index([isFeatured])
  @@index([isEditorPick])
}

model School {
  id          String  @id @default(cuid())
  name        String
  slug        String? @unique
  city        String?
  logoUrl     String?
  coverUrl    String?
  description String?
  website     String?
  isFeatured  Boolean @default(false)
  status      String  @default("ACTIVE")

  teachers              Teacher[]
  works                 Work[]
  exhibitions           Exhibition[]
  challenges            Challenge[]
  collaborationProjects CollaborationProject[]
  caseStudies           CaseStudy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isFeatured])
  @@index([status])
}

model Teacher {
  id         String  @id @default(cuid())
  userId     String?
  schoolId   String?
  name       String
  slug       String? @unique
  title      String?
  department String?
  avatarUrl  String?
  bio        String?
  contact    String?
  isFeatured Boolean @default(false)
  status     String  @default("PENDING")

  school                School?                  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  works                 Work[]
  recommendations       TeacherRecommendedWork[]
  exhibitions           Exhibition[]
  challenges            Challenge[]
  collaborationProjects CollaborationProject[]
  caseStudies           CaseStudy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([isFeatured])
  @@index([status])
}

model TeacherRecommendedWork {
  id        String  @id @default(cuid())
  teacherId String?
  workId    String
  note      String?
  tag       String?

  teacher Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  work    Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([workId])
}

model Exhibition {
  id          String           @id @default(cuid())
  schoolId    String?
  teacherId   String?
  title       String
  slug        String?          @unique
  type        String
  coverUrl    String?
  description String?
  startDate   DateTime?
  endDate     DateTime?
  isFeatured  Boolean          @default(false)
  status      ExhibitionStatus @default(DRAFT)

  school  School?          @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  teacher Teacher?         @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  works   ExhibitionWork[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([teacherId])
  @@index([status])
  @@index([isFeatured])
}

model ExhibitionWork {
  id           String  @id @default(cuid())
  exhibitionId String
  workId       String
  sortOrder    Int     @default(0)
  isFeatured   Boolean @default(false)

  exhibition Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  work       Work       @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([exhibitionId, workId])
  @@index([exhibitionId])
  @@index([workId])
}

model WorkIncubation {
  id        String               @id @default(cuid())
  workId    String               @unique
  status    WorkIncubationStatus @default(DISPLAYING)
  adminNote String?

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model WorkImage {
  id        String @id @default(cuid())
  workId    String
  imageUrl  String
  sortOrder Int

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
}

model Provider {
  id           String         @id @default(cuid())
  name         String
  slug         String?        @unique
  type         ProviderType
  logoUrl      String?
  coverUrl     String?
  city         String?
  province     String?
  country      String         @default("China")
  description  String?
  contactName  String?
  contactPhone String?
  contactEmail String?
  wechat       String?
  website      String?
  tags         String[]
  isVerified   Boolean        @default(false)
  isFeatured   Boolean        @default(false)
  status       ProviderStatus @default(PENDING)

  fabrics               Fabric[]
  fabricRecommendations WorkFabricRecommendation[]
  workProposals         ProviderWorkProposal[]
  collaborationProjects CollaborationProject[]
  projectOrders         ProjectOrder[]
  reviews               Review[]
  caseStudies           CaseStudy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([isFeatured])
  @@index([isVerified])
}

model ProviderApplication {
  id           String                    @id @default(cuid())
  providerType ProviderType
  companyName  String
  contactName  String
  phone        String?
  email        String?
  wechat       String?
  city         String?
  description  String?
  status       ProviderApplicationStatus @default(PENDING)
  reviewNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerType])
  @@index([status])
}

model Fabric {
  id          String       @id @default(cuid())
  name        String
  slug        String?      @unique
  code        String?
  providerId  String?
  imageUrl    String?
  composition String?
  weight      String?
  width       String?
  color       String?
  texture     String?
  season      String?
  usage       String?
  description String?
  priceNote   String?
  moqNote     String?
  tags        String[]
  isFeatured  Boolean      @default(false)
  status      FabricStatus @default(ACTIVE)

  provider              Provider?                  @relation(fields: [providerId], references: [id], onDelete: SetNull)
  recommendations       WorkFabricRecommendation[]
  collaborationProjects CollaborationProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@index([status])
  @@index([isFeatured])
}

model WorkFabricRecommendation {
  id            String               @id @default(cuid())
  workId        String
  fabricId      String
  providerId    String?
  reason        String?
  recommendedBy String?
  status        RecommendationStatus @default(PENDING)

  work     Work      @relation(fields: [workId], references: [id], onDelete: Cascade)
  fabric   Fabric    @relation(fields: [fabricId], references: [id], onDelete: Cascade)
  provider Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workId, fabricId])
  @@index([workId])
  @@index([fabricId])
  @@index([providerId])
  @@index([status])
}

model ProviderWorkProposal {
  id             String                     @id @default(cuid())
  workId         String
  providerId     String
  type           ProviderWorkProposalType
  title          String
  description    String?
  estimatedPrice String?
  estimatedTime  String?
  moq            String?
  attachments    String[]
  status         ProviderWorkProposalStatus @default(PENDING)

  work     Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([providerId])
  @@index([type])
  @@index([status])
}

model Challenge {
  id           String          @id @default(cuid())
  schoolId     String?
  teacherId    String?
  title        String
  slug         String?         @unique
  theme        String
  coverUrl     String?
  description  String
  requirements String
  rewards      String
  startAt      DateTime
  endAt        DateTime
  isFeatured   Boolean         @default(false)
  status       ChallengeStatus @default(DRAFT)

  school  School?          @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  teacher Teacher?         @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  entries ChallengeEntry[]
  works   ChallengeWork[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([teacherId])
  @@index([status])
  @@index([isFeatured])
}

model ChallengeWork {
  id          String  @id @default(cuid())
  challengeId String
  workId      String
  sortOrder   Int     @default(0)
  isFeatured  Boolean @default(false)

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  work      Work      @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([challengeId, workId])
  @@index([challengeId])
  @@index([workId])
}

model ChallengeEntry {
  id              String  @id @default(cuid())
  challengeId     String
  workId          String
  userId          String
  popularityScore Int     @default(0)
  incubationScore Int     @default(0)
  adminWeight     Int     @default(0)
  manualRank      Int?
  awardLevel      String?

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  work      Work      @relation(fields: [workId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([challengeId, workId])
  @@index([challengeId])
  @@index([userId])
}

model Like {
  id     String @id @default(cuid())
  userId String
  workId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, workId])
  @@index([workId])
}

model Favorite {
  id     String @id @default(cuid())
  userId String
  workId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, workId])
  @@index([workId])
}

model Comment {
  id          String        @id @default(cuid())
  userId      String
  workId      String
  content     String
  status      ContentStatus @default(VISIBLE)
  adminNote   String?
  handledAt   DateTime?
  handledById String?

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  work      Work  @relation(fields: [workId], references: [id], onDelete: Cascade)
  handledBy User? @relation("CommentHandledBy", fields: [handledById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([status])
}

model Follow {
  id          String @id @default(cuid())
  followerId  String
  followingId String

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([followerId, followingId])
}

model IncubationRecommendation {
  id     String @id @default(cuid())
  userId String
  workId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, workId])
  @@index([workId])
}

model IncubationApplication {
  id          String                      @id @default(cuid())
  userId      String
  workId      String
  source      IncubationSource
  status      IncubationApplicationStatus @default(CANDIDATE)
  adminNote   String?
  handledAt   DateTime?
  handledById String?

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  work      Work  @relation(fields: [workId], references: [id], onDelete: Cascade)
  handledBy User? @relation("IncubationApplicationHandledBy", fields: [handledById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([status])
}

model IncubationProject {
  id              String           @id @default(cuid())
  workId          String
  designerId      String
  status          IncubationStatus @default(CANDIDATE)
  platformComment String?
  nextAction      String?
  adminNote       String?
  handledAt       DateTime?
  handledById     String?

  work      Work  @relation(fields: [workId], references: [id], onDelete: Cascade)
  designer  User  @relation("IncubationProjectDesigner", fields: [designerId], references: [id], onDelete: Cascade)
  handledBy User? @relation("IncubationProjectHandledBy", fields: [handledById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([designerId])
  @@index([status])
}

model EditorialPick {
  id     String  @id @default(cuid())
  workId String
  type   String
  note   String?

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workId, type])
  @@index([workId])
  @@index([type])
}

model FabricProposal {
  id           String         @id @default(cuid())
  workId       String
  proposerName String
  companyName  String?
  contact      String
  fabricName   String
  composition  String?
  weight       String?
  width        String?
  priceRange   String?
  reason       String?
  imageUrl     String?
  status       ProposalStatus @default(PENDING)

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([status])
}

model SampleProposal {
  id           String         @id @default(cuid())
  workId       String
  proposerName String
  studioName   String?
  contact      String
  serviceType  String?
  category     String?
  leadTime     String?
  priceRange   String?
  message      String?
  status       ProposalStatus @default(PENDING)

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([status])
}

model FactoryProposal {
  id             String         @id @default(cuid())
  workId         String
  proposerName   String
  factoryName    String?
  contact        String
  category       String?
  moq            String?
  leadTime       String?
  unitPriceRange String?
  message        String?
  status         ProposalStatus @default(PENDING)

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([status])
}

model BuyerIntent {
  id              String         @id @default(cuid())
  workId          String
  buyerName       String
  companyName     String?
  contact         String
  channelType     String?
  quantity        String?
  targetPrice     String?
  cooperationType String?
  message         String?
  status          ProposalStatus @default(PENDING)

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([status])
}

model PresaleIntent {
  id              String         @id @default(cuid())
  workId          String
  name            String
  contact         String
  size            String?
  color           String?
  quantity        String?
  acceptablePrice String?
  message         String?
  status          ProposalStatus @default(PENDING)

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([status])
}

model PresaleCampaign {
  id             String                @id @default(cuid())
  workId         String
  title          String
  slug           String?               @unique
  description    String?
  targetCount    Int                   @default(50)
  currentCount   Int                   @default(0)
  estimatedPrice String?
  priceNote      String?
  sizeOptions    String[]
  colorOptions   String[]
  startDate      DateTime?
  endDate        DateTime?
  status         PresaleCampaignStatus @default(DRAFT)
  isFeatured     Boolean               @default(false)
  createdById    String?

  work                  Work                    @relation(fields: [workId], references: [id], onDelete: Cascade)
  createdBy             User?                   @relation("PresaleCampaignCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  intents               PresaleCampaignIntent[]
  collaborationProjects CollaborationProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([createdById])
  @@index([status])
  @@index([isFeatured])
}

model PresaleCampaignIntent {
  id         String                      @id @default(cuid())
  campaignId String
  workId     String
  userId     String?
  name       String?
  phone      String?
  email      String?
  wechat     String?
  size       String?
  color      String?
  quantity   Int                         @default(1)
  note       String?
  source     String?
  status     PresaleCampaignIntentStatus @default(SUBMITTED)

  campaign PresaleCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  work     Work            @relation(fields: [workId], references: [id], onDelete: Cascade)
  user     User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([workId])
  @@index([userId])
  @@index([status])
}

model VerificationRequest {
  id               String             @id @default(cuid())
  userId           String
  persona          UserPersona
  type             VerificationType
  realName         String?
  organizationName String?
  roleTitle        String?
  phone            String?
  email            String?
  wechat           String?
  city             String?
  description      String?
  proofUrl         String?
  status           VerificationStatus @default(PENDING)
  reviewNote       String?
  reviewedAt       DateTime?
  reviewedById     String?

  user       User  @relation("VerificationRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("VerificationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([persona])
  @@index([type])
  @@index([status])
}

model CollaborationProject {
  id                String                       @id @default(cuid())
  title             String
  slug              String?                      @unique
  workId            String
  designerId        String?
  schoolId          String?
  teacherId         String?
  providerId        String?
  fabricId          String?
  presaleCampaignId String?
  description       String?
  status            CollaborationProjectStatus   @default(DRAFT)
  priority          CollaborationProjectPriority @default(NORMAL)
  targetQuantity    String?
  estimatedBudget   String?
  targetLaunchDate  DateTime?
  internalNote      String?
  createdById       String?

  work            Work             @relation(fields: [workId], references: [id], onDelete: Cascade)
  designer        User?            @relation("CollaborationProjectDesigner", fields: [designerId], references: [id], onDelete: SetNull)
  school          School?          @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  teacher         Teacher?         @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  provider        Provider?        @relation(fields: [providerId], references: [id], onDelete: SetNull)
  fabric          Fabric?          @relation(fields: [fabricId], references: [id], onDelete: SetNull)
  presaleCampaign PresaleCampaign? @relation(fields: [presaleCampaignId], references: [id], onDelete: SetNull)
  createdBy       User?            @relation("CollaborationProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  orders          ProjectOrder[]
  reviews         Review[]
  caseStudies     CaseStudy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([designerId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([providerId])
  @@index([fabricId])
  @@index([presaleCampaignId])
  @@index([status])
  @@index([priority])
}

model ProjectOrder {
  id           String             @id @default(cuid())
  projectId    String
  workId       String?
  buyerId      String?
  providerId   String?
  title        String
  quantityNote String?
  amountNote   String?
  deliveryNote String?
  status       ProjectOrderStatus @default(INTENT)
  note         String?

  project  CollaborationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  work     Work?                @relation(fields: [workId], references: [id], onDelete: SetNull)
  buyer    User?                @relation("ProjectOrderBuyer", fields: [buyerId], references: [id], onDelete: SetNull)
  provider Provider?            @relation(fields: [providerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([workId])
  @@index([buyerId])
  @@index([providerId])
  @@index([status])
}

model Review {
  id           String           @id @default(cuid())
  reviewerId   String
  targetType   ReviewTargetType
  targetUserId String?
  providerId   String?
  workId       String?
  projectId    String?
  rating       Int              @default(5)
  content      String?
  status       ReviewStatus     @default(PENDING)

  reviewer   User                  @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  targetUser User?                 @relation("ReviewTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  provider   Provider?             @relation(fields: [providerId], references: [id], onDelete: SetNull)
  work       Work?                 @relation(fields: [workId], references: [id], onDelete: SetNull)
  project    CollaborationProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewerId])
  @@index([targetType])
  @@index([targetUserId])
  @@index([providerId])
  @@index([workId])
  @@index([projectId])
  @@index([status])
}

model CaseStudy {
  id           String          @id @default(cuid())
  title        String
  slug         String          @unique
  coverUrl     String?
  summary      String?
  content      String?
  workId       String?
  projectId    String?
  schoolId     String?
  teacherId    String?
  providerId   String?
  designerName String?
  resultNote   String?
  isFeatured   Boolean         @default(false)
  status       CaseStudyStatus @default(DRAFT)

  work     Work?                 @relation(fields: [workId], references: [id], onDelete: SetNull)
  project  CollaborationProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  school   School?               @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  teacher  Teacher?              @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  provider Provider?             @relation(fields: [providerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([projectId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([providerId])
  @@index([status])
  @@index([isFeatured])
}

model FabricRequest {
