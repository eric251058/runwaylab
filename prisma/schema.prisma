model User {
  id               String      @id @default(cuid())
  email            String?     @unique
  phone            String?     @unique
  emailVerifiedAt  DateTime?
  phoneVerifiedAt  DateTime?
  passwordHash     String
  nickname         String
  avatarUrl        String?
  role             UserRole    @default(USER)
  status           UserStatus  @default(ACTIVE)
  persona          UserPersona @default(CONSUMER)
  personaCompleted Boolean     @default(false)

  designerProfile              DesignerProfile?
  sessions                     AuthSession[]
  works                        Work[]
  comments                     Comment[]
  likes                        Like[]
  favorites                    Favorite[]
  challengeEntries             ChallengeEntry[]
  follows                      Follow[]                   @relation("Follower")
  followers                    Follow[]                   @relation("Following")
  incubationRecommendations    IncubationRecommendation[]
  incubationApplications       IncubationApplication[]
  incubationProjects           IncubationProject[]        @relation("IncubationProjectDesigner")
  fabricRequests               FabricRequest[]
  sampleRequests               SampleRequest[]
  cooperationRequests          CooperationRequest[]
  sentCooperationReplies       CooperationRequestReply[]  @relation("CooperationRequestReplySender")
  reports                      Report[]                   @relation("Reporter")
  notifications                Notification[]
  createdFabricRecommendations WorkFabricRecommendation[] @relation("WorkFabricRecommendationCreatedBy")

  handledWorks                          Work[]                       @relation("WorkHandledBy")
  handledComments                       Comment[]                    @relation("CommentHandledBy")
  handledApplications                   IncubationApplication[]      @relation("IncubationApplicationHandledBy")
  handledProjects                       IncubationProject[]          @relation("IncubationProjectHandledBy")
  handledFabricRequests                 FabricRequest[]              @relation("FabricRequestHandledBy")
  handledSampleRequests                 SampleRequest[]              @relation("SampleRequestHandledBy")
  handledCooperationRequests            CooperationRequest[]         @relation("CooperationRequestHandledBy")
  handledReports                        Report[]                     @relation("ReportHandledBy")
  adminLogs                             AdminLog[]
  presaleCampaigns                      PresaleCampaign[]            @relation("PresaleCampaignCreatedBy")
  presaleCampaignIntents                PresaleCampaignIntent[]
  verificationRequests                  VerificationRequest[]        @relation("VerificationRequestUser")
  reviewedVerifications                 VerificationRequest[]        @relation("VerificationReviewedBy")
  collaborationProjects                 CollaborationProject[]       @relation("CollaborationProjectDesigner")
  ownedCollaborationProjects            CollaborationProject[]       @relation("CollaborationProjectOwner")
  createdProjects                       CollaborationProject[]       @relation("CollaborationProjectCreatedBy")
  demandIntents                         WorkDemandIntent[]
  projectDesignAuthorizationsAsDesigner ProjectDesignAuthorization[] @relation("ProjectDesignAuthorizationDesigner")
  projectDesignAuthorizationsAsOwner    ProjectDesignAuthorization[] @relation("ProjectDesignAuthorizationOwner")
  createdProjectMilestones              ProjectMilestone[]           @relation("ProjectMilestoneCreatedBy")
  projectIssues                         ProjectIssue[]               @relation("ProjectIssueReporter")
  projectOrders                         ProjectOrder[]               @relation("ProjectOrderBuyer")
  givenReviews                          Review[]                     @relation("ReviewReviewer")
  receivedReviews                       Review[]                     @relation("ReviewTargetUser")
  createdIncubationBatches              IncubationBatch[]            @relation("IncubationBatchCreatedBy")
  requestedAiDiagnoses                  WorkAiDiagnosis[]            @relation("WorkAiDiagnosisRequestedBy")
  reviewedAiDiagnoses                   WorkAiDiagnosis[]            @relation("WorkAiDiagnosisReviewedBy")
  ownedProviders                        Provider[]                   @relation("ProviderOwner")
  providerApplications                  ProviderApplication[]        @relation("ProviderApplicationUser")
  reviewedProviderShowcaseItems         ProviderShowcaseItem[]       @relation("ProviderShowcaseReviewedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model DesignerProfile {
  id                String  @id @default(cuid())
  userId            String  @unique
  school            String?
  city              String?
  designDirection   String?
  bio               String?
  cooperationStatus String?
  portfolioCoverUrl String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Work {
  id               String            @id @default(cuid())
  userId           String
  schoolId         String?
  teacherId        String?
  title            String
  description      String
  category         String
  workType         String
  styleTags        String[]
  reviewStatus     ReviewStatus      @default(PENDING)
  rejectReason     String?
  contentStatus    ContentStatus     @default(VISIBLE)
  isOriginal       Boolean           @default(false)
  isAiAssisted     Boolean           @default(false)
  isFeatured       Boolean           @default(false)
  isEditorPick     Boolean           @default(false)
  isOpenCoop       Boolean           @default(false)
  wantsFabric      Boolean           @default(false)
  wantsSample      Boolean           @default(false)
  wantsIncubation  Boolean           @default(false)
  incubationStatus IncubationStatus?

  viewCount                Int @default(0)
  likeCount                Int @default(0)
  favoriteCount            Int @default(0)
  commentCount             Int @default(0)
  shareCount               Int @default(0)
  incubationRecommendCount Int @default(0)

  adminNote   String?
  handledAt   DateTime?
  handledById String?

  user                         User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  school                       School?                       @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  teacher                      Teacher?                      @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  handledBy                    User?                         @relation("WorkHandledBy", fields: [handledById], references: [id])
  images                       WorkImage[]
  comments                     Comment[]
  likes                        Like[]
  favorites                    Favorite[]
  challengeEntries             ChallengeEntry[]
  challengeWorks               ChallengeWork[]
  exhibitionWorks              ExhibitionWork[]
  teacherRecommendations       TeacherRecommendedWork[]
  incubationRecommendations    IncubationRecommendation[]
  incubationApplications       IncubationApplication[]
  incubationProjects           IncubationProject[]
  workIncubation               WorkIncubation?
  fabricProposals              FabricProposal[]
  sampleProposals              SampleProposal[]
  factoryProposals             FactoryProposal[]
  buyerIntents                 BuyerIntent[]
  presaleIntents               PresaleIntent[]
  presaleCampaigns             PresaleCampaign[]
  presaleCampaignIntents       PresaleCampaignIntent[]
  collaborationProjects        CollaborationProject[]
  projectOrders                ProjectOrder[]
  reviews                      Review[]
  caseStudies                  CaseStudy[]
  fabricRecommendations        WorkFabricRecommendation[]
  providerWorkProposals        ProviderWorkProposal[]
  editorialPicks               EditorialPick[]
  fabricRequests               FabricRequest[]
  sampleRequests               SampleRequest[]
  cooperationRequests          CooperationRequest[]
  votes                        WorkVote[]
  contributions                WorkContribution[]
  opportunityProfile           WorkOpportunityProfile?
  providerOpportunityInterests ProviderOpportunityInterest[]
  incubationBatchWorks         IncubationBatchWork[]
  aiDiagnoses                  WorkAiDiagnosis[]
  demandIntents                WorkDemandIntent[]
  projectDesignAuthorizations  ProjectDesignAuthorization[]
  projectProducts              ProjectProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([reviewStatus, contentStatus])
  @@index([isFeatured])
  @@index([isEditorPick])
}

model School {
  id          String  @id @default(cuid())
  name        String
  slug        String? @unique
  city        String?
  logoUrl     String?
  coverUrl    String?
  description String?
  website     String?
  isFeatured  Boolean @default(false)
  status      String  @default("ACTIVE")

  teachers              Teacher[]
  works                 Work[]
  exhibitions           Exhibition[]
  challenges            Challenge[]
  collaborationProjects CollaborationProject[]
  caseStudies           CaseStudy[]
  incubationBatches     IncubationBatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isFeatured])
  @@index([status])
}

model Teacher {
  id         String  @id @default(cuid())
  userId     String?
  schoolId   String?
  name       String
  slug       String? @unique
  title      String?
  department String?
  avatarUrl  String?
  bio        String?
  contact    String?
  isFeatured Boolean @default(false)
  status     String  @default("PENDING")

  school                School?                  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  works                 Work[]
  recommendations       TeacherRecommendedWork[]
  exhibitions           Exhibition[]
  challenges            Challenge[]
  collaborationProjects CollaborationProject[]
  caseStudies           CaseStudy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([isFeatured])
  @@index([status])
}

model TeacherRecommendedWork {
  id        String  @id @default(cuid())
  teacherId String?
  workId    String
  note      String?
  tag       String?

  teacher Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  work    Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([workId])
}

model Exhibition {
  id          String           @id @default(cuid())
  schoolId    String?
  teacherId   String?
  title       String
  slug        String?          @unique
  type        String
  coverUrl    String?
  description String?
  startDate   DateTime?
  endDate     DateTime?
  isFeatured  Boolean          @default(false)
  status      ExhibitionStatus @default(DRAFT)

  school  School?          @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  teacher Teacher?         @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  works   ExhibitionWork[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([teacherId])
  @@index([status])
  @@index([isFeatured])
}

model ExhibitionWork {
  id           String  @id @default(cuid())
  exhibitionId String
  workId       String
  sortOrder    Int     @default(0)
  isFeatured   Boolean @default(false)

  exhibition Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  work       Work       @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([exhibitionId, workId])
  @@index([exhibitionId])
  @@index([workId])
}

model WorkDemandIntent {
  id                  String                 @id @default(cuid())
  workId              String
  userId              String
  preferredSizes      String[]
  preferredColors     String[]
  priceMin            Int?
  priceMax            Int?
  region              String?
  notifyWhenAvailable Boolean                @default(true)
  status              WorkDemandIntentStatus @default(ACTIVE)

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workId, userId])
  @@index([workId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model WorkIncubation {
  id        String               @id @default(cuid())
  workId    String               @unique
  status    WorkIncubationStatus @default(DISPLAYING)
  adminNote String?

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model WorkAiDiagnosis {
  id      String            @id @default(cuid())
  workId  String
  status  AiDiagnosisStatus @default(PENDING)
  version Int               @default(1)

  designSummary       String?
  designHighlights    String?
  targetAudience      String?
  suitableScenes      String?
  suggestedCategories String?
  suggestedMaterials  String?
  suggestedTechniques String?
  productionRisks     String?
  missingInformation  String?
  nextStepSuggestions String?

  professionalAssessment String?
  productionAssessment   String?
  marketAssessment       String?

  confidence    Int?
  modelProvider String?
  modelName     String?
  promptVersion String?

  rawResponse Json?

  requestedById String?
  reviewedById  String?

  reviewStatus AiDiagnosisReviewStatus @default(UNREVIEWED)
  adminNote    String?
  errorMessage String?

  work        Work  @relation(fields: [workId], references: [id], onDelete: Cascade)
  requestedBy User? @relation("WorkAiDiagnosisRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  reviewedBy  User? @relation("WorkAiDiagnosisReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([status])
  @@index([reviewStatus])
  @@index([createdAt])
}

model WorkImage {
  id        String @id @default(cuid())
  workId    String
  imageUrl  String
  sortOrder Int

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
}

model WorkVote {
  id           String         @id @default(cuid())
  workId       String
  actorKey     String
  type         WorkVoteType
  voterName    String?
  voterContact String?
  voterPersona String?
  status       WorkVoteStatus @default(ACTIVE)
  adminNote    String?

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workId, actorKey])
  @@index([workId])
  @@index([type])
  @@index([createdAt])
  @@index([actorKey, createdAt])
  @@index([workId, status, type])
}

model WorkContribution {
  id        String              @id @default(cuid())
  workId    String
  actorKey  String
  persona   ContributionPersona
  type      ContributionType
  content   String
  name      String?
  contact   String?
  status    ContributionStatus  @default(NEW)
  adminNote String?

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([persona])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([actorKey, createdAt])
  @@index([workId, status, createdAt])
}

model Provider {
  id                    String                     @id @default(cuid())
  ownerId               String?
  name                  String
  slug                  String?                    @unique
  type                  ProviderType
  logoUrl               String?
  coverUrl              String?
  tagline               String?
  city                  String?
  address               String?
  province              String?
  country               String                     @default("China")
  description           String?
  contactName           String?
  contactPhone          String?
  contactEmail          String?
  wechat                String?
  whatsapp              String?
  website               String?
  tags                  String[]
  specialties           String[]                   @default([])
  categories            String[]                   @default([])
  materials             String[]                   @default([])
  techniques            String[]                   @default([])
  serviceRegions        String[]                   @default([])
  serviceArea           String?
  responseTime          String?
  isVerified            Boolean                    @default(false)
  isFeatured            Boolean                    @default(false)
  status                ProviderStatus             @default(PENDING)
  orderPreference       ProviderOrderPreference    @default(FLEXIBLE)
  minimumOrderQuantity  Int?
  maximumOrderQuantity  Int?
  moqMin                Int?
  acceptsSampling       Boolean                    @default(true)
  acceptsSmallBatch     Boolean                    @default(false)
  acceptsLargeOrder     Boolean                    @default(false)
  sampleSupported       Boolean?
  singleSampleSupported Boolean?
  patternMaking         String?
  minimumOrder          String?
  sampleLeadDays        Int?
  productionLeadDays    Int?
  leadTime              String?
