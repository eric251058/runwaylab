  @@index([designerAuthorizationStatus])
  @@index([priority])
}

model ProjectDesignAuthorization {
  id                 String                           @id @default(cuid())
  projectId          String
  workId             String
  designerUserId     String
  ownerUserId        String
  scope              String
  royaltyDescription String?
  status             ProjectDesignAuthorizationStatus @default(PENDING)
  requestedAt        DateTime                         @default(now())
  acceptedAt         DateTime?
  revokedAt          DateTime?
  termsVersion       String                           @default("v1")

  project  CollaborationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  work     Work                 @relation(fields: [workId], references: [id], onDelete: Cascade)
  designer User                 @relation("ProjectDesignAuthorizationDesigner", fields: [designerUserId], references: [id], onDelete: Cascade)
  owner    User                 @relation("ProjectDesignAuthorizationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId])
  @@index([projectId])
  @@index([workId])
  @@index([designerUserId])
  @@index([ownerUserId])
  @@index([status])
}

model ProjectMilestone {
  id              String                     @id @default(cuid())
  projectId       String
  title           String
  stage           String
  status          ProjectMilestoneStatus     @default(TODO)
  dueAt           DateTime?
  completedAt     DateTime?
  note            String?
  evidenceUrl     String?
  visibility      ProjectMilestoneVisibility @default(PARTICIPANTS)
  createdByUserId String?

  project   CollaborationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?                @relation("ProjectMilestoneCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([visibility])
  @@index([createdByUserId])
}

model ProjectIssue {
  id          String             @id @default(cuid())
  projectId   String
  reporterId  String
  type        ProjectIssueType   @default(OTHER)
  title       String
  description String?
  status      ProjectIssueStatus @default(OPEN)
  adminNote   String?
  resolvedAt  DateTime?

  project  CollaborationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporter User                 @relation("ProjectIssueReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([reporterId])
  @@index([type])
  @@index([status])
}

model ProjectProduct {
  id                  String               @id @default(cuid())
  projectId           String
  workId              String?
  title               String
  description         String?
  materialDescription String?
  careInstructions    String?
  price               Int
  currency            String               @default("CNY")
  targetQuantity      Int?
  preorderDeadline    DateTime?
  estimatedShipDate   DateTime?
  imageStage          String?
  status              ProjectProductStatus @default(DRAFT)

  project CollaborationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  work    Work?                @relation(fields: [workId], references: [id], onDelete: SetNull)
  skus    ProjectSku[]
  orders  ProjectOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([workId])
  @@index([status])
}

model ProjectSku {
  id            String  @id @default(cuid())
  productId     String
  size          String
  color         String
  skuCode       String?
  priceOverride Int?
  capacity      Int?
  enabled       Boolean @default(true)

  product ProjectProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders  ProjectOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, size, color])
  @@index([productId])
  @@index([enabled])
}

model ProjectOrder {
  id                      String                        @id @default(cuid())
  projectId               String
  workId                  String?
  productId               String?
  skuId                   String?
  buyerId                 String?
  providerId              String?
  title                   String
  quantity                Int                           @default(1)
  unitPrice               Int?
  totalAmount             Int?
  currency                String                        @default("CNY")
  quantityNote            String?
  amountNote              String?
  deliveryNote            String?
  status                  ProjectOrderStatus            @default(INTENT)
  paymentStatus           ProjectOrderPaymentStatus     @default(UNPAID)
  fulfillmentStatus       ProjectOrderFulfillmentStatus @default(NOT_STARTED)
  shippingAddressSnapshot Json?
  buyerNote               String?
  trackingCompany         String?
  trackingNumber          String?
  estimatedShipDate       DateTime?
  exceptionNote           String?
  note                    String?

  project  CollaborationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  work     Work?                @relation(fields: [workId], references: [id], onDelete: SetNull)
  product  ProjectProduct?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  sku      ProjectSku?          @relation(fields: [skuId], references: [id], onDelete: SetNull)
  buyer    User?                @relation("ProjectOrderBuyer", fields: [buyerId], references: [id], onDelete: SetNull)
  provider Provider?            @relation(fields: [providerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([workId])
  @@index([productId])
  @@index([skuId])
  @@index([buyerId])
  @@index([providerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([fulfillmentStatus])
}

model Review {
  id           String           @id @default(cuid())
  reviewerId   String
  targetType   ReviewTargetType
  targetUserId String?
  providerId   String?
  workId       String?
  projectId    String?
  rating       Int              @default(5)
  content      String?
  status       ReviewStatus     @default(PENDING)

  reviewer   User                  @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  targetUser User?                 @relation("ReviewTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  provider   Provider?             @relation(fields: [providerId], references: [id], onDelete: SetNull)
  work       Work?                 @relation(fields: [workId], references: [id], onDelete: SetNull)
  project    CollaborationProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewerId])
  @@index([targetType])
  @@index([targetUserId])
  @@index([providerId])
  @@index([workId])
  @@index([projectId])
  @@index([status])
}

model CaseStudy {
  id           String          @id @default(cuid())
  title        String
  slug         String          @unique
  coverUrl     String?
  summary      String?
  content      String?
  workId       String?
  projectId    String?
  schoolId     String?
  teacherId    String?
  providerId   String?
  designerName String?
  resultNote   String?
  isFeatured   Boolean         @default(false)
  status       CaseStudyStatus @default(DRAFT)

  work     Work?                 @relation(fields: [workId], references: [id], onDelete: SetNull)
  project  CollaborationProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  school   School?               @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  teacher  Teacher?              @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  provider Provider?             @relation(fields: [providerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([projectId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([providerId])
  @@index([status])
  @@index([isFeatured])
}

model FabricRequest {
  id             String        @id @default(cuid())
  userId         String
  workId         String?
  category       String?
  desiredFeeling String[]
  colorDirection String?
  budgetRange    String?
  contact        String
  remark         String?
  status         RequestStatus @default(PENDING)
  adminNote      String?
  handledAt      DateTime?
  handledById    String?

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  work      Work? @relation(fields: [workId], references: [id], onDelete: SetNull)
  handledBy User? @relation("FabricRequestHandledBy", fields: [handledById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([workId])
  @@index([status])
}

model SampleRequest {
  id              String        @id @default(cuid())
  userId          String
  workId          String?
  garmentCategory String?
  hasPattern      Boolean       @default(false)
  hasFabric       Boolean       @default(false)
  needsFabricHelp Boolean       @default(false)
  budgetRange     String?
  quantity        Int?
  expectedDate    DateTime?
  contact         String
  remark          String?
  status          RequestStatus @default(PENDING)
  adminNote       String?
  handledAt       DateTime?
  handledById     String?

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  work      Work? @relation(fields: [workId], references: [id], onDelete: SetNull)
  handledBy User? @relation("SampleRequestHandledBy", fields: [handledById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([workId])
  @@index([status])
}

model CooperationRequest {
  id                String              @id @default(cuid())
  userId            String
  workId            String?
  providerId        String?
  fabricId          String?
  showcaseItemId    String?
  type              CooperationType
  requestType       ProviderInquiryType @default(GENERAL)
  contact           String
  contactPreference String?
  quantity          Int?
  expectedDate      DateTime?
  message           String?
  budgetRange       String?
  providerResponse  String?
  status            RequestStatus       @default(PENDING)
  adminNote         String?
  viewedAt          DateTime?
  respondedAt       DateTime?
  handledAt         DateTime?
  handledById       String?

  user         User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  work         Work?                     @relation(fields: [workId], references: [id], onDelete: SetNull)
  provider     Provider?                 @relation(fields: [providerId], references: [id], onDelete: SetNull)
  fabric       Fabric?                   @relation(fields: [fabricId], references: [id], onDelete: SetNull)
  showcaseItem ProviderShowcaseItem?     @relation(fields: [showcaseItemId], references: [id], onDelete: SetNull)
  handledBy    User?                     @relation("CooperationRequestHandledBy", fields: [handledById], references: [id])
  replies      CooperationRequestReply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([workId])
  @@index([providerId])
  @@index([fabricId])
  @@index([showcaseItemId])
  @@index([requestType])
  @@index([status])
  @@index([createdAt])
}

model CooperationRequestReply {
  id         String  @id @default(cuid())
  inquiryId  String
  senderId   String
  senderRole String
  content    String
  isRead     Boolean @default(false)

  inquiry CooperationRequest @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  sender  User               @relation("CooperationRequestReplySender", fields: [senderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inquiryId, createdAt])
  @@index([senderId])
  @@index([isRead])
}

model Report {
  id          String           @id @default(cuid())
  reporterId  String
  targetType  ReportTargetType
  targetId    String
  reason      ReportReason
  description String?
  status      ReportStatus     @default(PENDING)
  result      String?
  adminNote   String?
  handledAt   DateTime?
  handledById String?

  reporter  User  @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  handledBy User? @relation("ReportHandledBy", fields: [handledById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([status])
}

model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  title   String
  content String
  isRead  Boolean          @default(false)
  linkUrl String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isRead])
}

model SystemSetting {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminLog {
  id         String @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  detail     Json?

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminId])
  @@index([targetType, targetId])
}
